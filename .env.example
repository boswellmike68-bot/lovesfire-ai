# LovesfireAI Environment Configuration

# Application
NODE_ENV=development
PORT=3000

# Video Backend Configuration
VIDEO_BACKEND=mock
# Options: mock, pika, runway

# Render Configuration
WORKER_COUNT=2
RENDER_TIMEOUT_MS=600000
CLEANUP_AFTER_MS=3600000
DRY_RUN=false

# Stripe Payment Configuration
# Financial email (NEVER commit the real address — set in .env only):
STRIPE_ACCOUNT_EMAIL=your_financial_email@example.com
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Public Contact
# For general inquiries and technical support:
CONTACT_EMAIL=bossbozitive@outlook.com
CONTACT_NAME=Mike
